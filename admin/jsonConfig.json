{
	"i18n": true,
	"type": "panel",
	"items": {
		"iometerIp": {
			"type": "text",
			"label": "iometer IP address",
			"placeholder": "192.168.1.100",
			"sm": 12,
			"md": 6,
			"validators": [
				{
					"type": "pattern",
					"pattern": "^(\\d{1,3}\\.){3}\\d{1,3}$",
					"message": "Please enter a valid IP address"
				}
			]
		}
	}
}
